# Target directory (compiled binaries and build artifacts)
target/

# Cargo lock file (ignore for libraries, commit for applications)
Cargo.lock

# Build artifacts
**/*.rlib
**/*.rmeta

# Rustup-specific directories
.rustup/
.cargo/

# Debugging files
.gdb_history
.lldb

# Logs and temporary files
*.log
*.tmp

# Editor and IDE files
.idea/
.vscode/
.zed/
*.swp
*.swo

# Coverage and test reports
coverage/
*.profdata
*.gcda
*.gcno
